{
  "name": "graphql-sentinel",
  "version": "0.1.0",
  "description": "Comprehensive GraphQL security scanner and runtime shield",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "graphql-sentinel": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "graphql",
    "security",
    "scanner",
    "shield",
    "vulnerability",
    "audit"
  ],
  "author": "Mark Stuart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mstuart/graphql-sentinel.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "graphql": "^16.12.0"
  },
  "peerDependenciesMeta": {
    "graphql-yoga": {
      "optional": true
    },
    "@apollo/server": {
      "optional": true
    }
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "graphql-yoga": "^5.18.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
