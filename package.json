{
  "name": "graphql-sentinel",
  "version": "1.0.0",
  "description": "Comprehensive GraphQL security scanner and runtime shield",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "graphql-sentinel": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "graphql",
    "security",
    "scanner",
    "shield",
    "vulnerability",
    "audit",
    "depth-limit",
    "rate-limit",
    "introspection",
    "complexity",
    "graphql-yoga",
    "apollo",
    "middleware",
    "typescript"
  ],
  "author": "Mark Stuart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mstuart/graphql-sentinel.git"
  },
  "homepage": "https://github.com/mstuart/graphql-sentinel#readme",
  "bugs": {
    "url": "https://github.com/mstuart/graphql-sentinel/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@apollo/server": "^4.0.0",
    "graphql": "^16.12.0",
    "graphql-yoga": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "graphql-yoga": {
      "optional": true
    },
    "@apollo/server": {
      "optional": true
    }
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^10.0.2",
    "graphql": "^16.12.0",
    "graphql-yoga": "^5.18.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
